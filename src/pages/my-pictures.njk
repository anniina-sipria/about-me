---
layout: layouts/page.njk
title: My Pictures
permalink: /my-pictures/
---

<p>A small photo gallery. Add image files to <code>src/assets/pictures</code> and rebuild.</p>

{% if pictures and pictures.length %}
  <ul class="gallery" aria-label="Picture gallery">
    {% for pic in pictures %}
      <li class="gallery__item">
        <a class="gallery__link" href="{{ pic.url }}">
          <img class="gallery__img" src="{{ pic.url }}" alt="{{ pic.alt }}" loading="lazy" />
        </a>
      </li>
    {% endfor %}
  </ul>
{% else %}
  <p>No pictures yet. Drop some <code>.jpg</code>/<code>.png</code>/<code>.webp</code> files into <code>src/assets/pictures</code>.</p>
{% endif %}
